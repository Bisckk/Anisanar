---
import { services } from '@data/services';

const contactInfo = [
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011.11-.27 11.36 11.36 0 003.55.71 1 1 0 011 1V20a1 1 0 01-1 1A17 17 0 013 4a1 1 0 011-1h3.5a1 1 0 011 1 11.36 11.36 0 00.71 3.55 1 1 0 01-.27 1.11l-2.32 2.13z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    label: 'Teléfono',
    value: '+34 000 000 000',
    href: 'tel:+34000000000',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M3 8l9 6 9-6M5 5h14a2 2 0 012 2v10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    label: 'Email',
    value: 'info@anisanar.com',
    href: 'mailto:info@anisanar.com',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5a2.5 2.5 0 110-5 2.5 2.5 0 010 5z" fill="currentColor" opacity=".3"/><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5a2.5 2.5 0 110-5 2.5 2.5 0 010 5z" stroke="currentColor" stroke-width="1.5"/></svg>`,
    label: 'Dirección',
    value: 'Calle Ejemplo 123, Madrid',
    href: 'https://maps.google.com',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"/><path d="M12 7v5l3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
    label: 'Horario',
    value: 'Lun–Vie: 9–20 h · Sáb: 9–14 h',
    href: null,
  },
];

const petTypes = ['Perro', 'Gato', 'Otro'];
---

<section id="contact" class="contact section-spacing" aria-labelledby="contact-heading">
  <div class="container-gutter">
    <div class="contact__grid">

      <!-- Left: info -->
      <div class="contact__info">
        <span class="contact__label reveal-up">Contacto</span>
        <h2 id="contact-heading" class="contact__heading reveal-up">
          Estamos aquí<br/>
          <em>para ti.</em>
        </h2>
        <p class="contact__body reveal-up">
          Agenda tu cita, pide información o cuéntanos cómo podemos ayudar
          a tu mascota. Te respondemos en menos de 24 horas.
        </p>

        <!-- Info list -->
        <ul class="contact__info-list" data-stagger-parent aria-label="Información de contacto">
          {contactInfo.map(({ icon, label, value, href }) => (
            <li class="contact__info-item" data-stagger-child>
              <span class="contact__info-icon" aria-hidden="true" set:html={icon} />
              <div>
                <span class="contact__info-label">{label}</span>
                {href ? (
                  <a href={href} class="contact__info-value" target={href.startsWith('http') ? '_blank' : undefined} rel={href.startsWith('http') ? 'noopener noreferrer' : undefined}>
                    {value}
                  </a>
                ) : (
                  <span class="contact__info-value">{value}</span>
                )}
              </div>
            </li>
          ))}
        </ul>
      </div>

      <!-- Right: form -->
      <div class="contact__form-col reveal-right">
        <form
          id="contact-form"
          class="contact__form"
          novalidate
          aria-label="Formulario de contacto"
          method="POST"
          action="#"
        >
          <div class="contact__form-row">
            <div class="contact__field">
              <label class="form-label" for="name">Nombre completo *</label>
              <input
                type="text"
                id="name"
                name="name"
                class="form-input"
                placeholder="Tu nombre"
                required
                autocomplete="name"
                aria-required="true"
              />
            </div>
            <div class="contact__field">
              <label class="form-label" for="email">Email *</label>
              <input
                type="email"
                id="email"
                name="email"
                class="form-input"
                placeholder="tu@email.com"
                required
                autocomplete="email"
                aria-required="true"
              />
            </div>
          </div>

          <div class="contact__form-row">
            <div class="contact__field">
              <label class="form-label" for="phone">Teléfono</label>
              <input
                type="tel"
                id="phone"
                name="phone"
                class="form-input"
                placeholder="+34 600 000 000"
                autocomplete="tel"
              />
            </div>
            <div class="contact__field">
              <label class="form-label" for="pet-type">Tipo de mascota</label>
              <select id="pet-type" name="pet-type" class="form-input" aria-label="Selecciona el tipo de mascota">
                <option value="">Seleccionar…</option>
                {petTypes.map((p) => <option value={p.toLowerCase()}>{p}</option>)}
              </select>
            </div>
          </div>

          <div class="contact__field">
            <label class="form-label" for="service">Servicio de interés</label>
            <select id="service" name="service" class="form-input" aria-label="Selecciona el servicio">
              <option value="">Seleccionar servicio…</option>
              {services.map((s) => <option value={s.id}>{s.title}</option>)}
              <option value="urgencia">Urgencia</option>
              <option value="otro">Otro</option>
            </select>
          </div>

          <div class="contact__field">
            <label class="form-label" for="message">Mensaje *</label>
            <textarea
              id="message"
              name="message"
              class="form-input contact__textarea"
              placeholder="Cuéntanos cómo podemos ayudar a tu mascota…"
              required
              aria-required="true"
              rows="5"
            ></textarea>
          </div>

          <!-- Feedback -->
          <div id="form-feedback" class="contact__feedback" role="alert" aria-live="assertive" aria-hidden="true"></div>

          <button type="submit" class="btn-primary contact__submit">
            Enviar mensaje
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </form>
      </div>
    </div>
  </div>
</section>

<style>
  .contact {
    background: white;
  }

  .contact__grid {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: clamp(3rem, 6vw, 7rem);
    align-items: start;
  }

  /* Info col */
  .contact__label {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #8CC63F;
    margin-bottom: 1.25rem;
  }

  .contact__heading {
    font-family: "Lexend", system-ui, sans-serif;
    font-size: clamp(2.25rem, 4vw, 3.75rem);
    font-weight: 500;
    line-height: 1.1;
    color: var(--color-charcoal);
    letter-spacing: -0.02em;
    margin-bottom: 1.25rem;
  }

  .contact__heading em { color: #8CC63F; }

  .contact__body {
    font-size: clamp(0.9375rem, 1.1vw, 1.0625rem);
    line-height: 1.75;
    color: rgba(30, 30, 30, 0.65);
    margin-bottom: 2.5rem;
  }

  .contact__info-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .contact__info-item {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }

  .contact__info-icon {
    width: 44px;
    height: 44px;
    background: rgba(140, 198, 63, 0.1);
    border-radius: 0.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--color-clay);
  }

  .contact__info-label {
    display: block;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(30, 30, 30, 0.45);
    margin-bottom: 0.2rem;
  }

  .contact__info-value {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-charcoal);
    text-decoration: none;
    transition: color 0.25s ease;
  }

  a.contact__info-value:hover { color: #8CC63F; }

  /* Form */
  .contact__form-col {
    background: var(--color-charcoal);
    border-radius: 1.5rem;
    padding: clamp(1.75rem, 3vw, 2.75rem);
  }

  .contact__form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .contact__form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .contact__field {
    display: flex;
    flex-direction: column;
  }

  .contact__textarea {
    resize: vertical;
    min-height: 120px;
  }

  .contact__feedback {
    padding: 0.875rem 1.125rem;
    border-radius: 0.75rem;
    font-size: 0.875rem;
    font-weight: 500;
    display: none;
  }

  .contact__feedback.success {
    display: block;
    background: rgba(122, 158, 142, 0.15);
    color: var(--color-charcoal);
    border: 1px solid rgba(122, 158, 142, 0.4);
  }

  .contact__feedback.error {
    display: block;
    background: rgba(140, 198, 63, 0.12);
    color: #8a3c1a;
    border: 1px solid rgba(140, 198, 63, 0.35);
  }

  .contact__submit {
    align-self: flex-start;
    margin-top: 0.5rem;
  }

  @media (max-width: 900px) {
    .contact__grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 480px) {
    .contact__form-row { grid-template-columns: 1fr; }
  }
</style>

<script>
  const form     = document.getElementById('contact-form') as HTMLFormElement;
  const feedback = document.getElementById('form-feedback')!;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    feedback.className = 'contact__feedback';
    feedback.setAttribute('aria-hidden', 'true');

    const name    = (form.elements.namedItem('name')    as HTMLInputElement).value.trim();
    const email   = (form.elements.namedItem('email')   as HTMLInputElement).value.trim();
    const message = (form.elements.namedItem('message') as HTMLTextAreaElement).value.trim();

    if (!name || !email || !message) {
      feedback.textContent = 'Por favor, completa los campos obligatorios (nombre, email y mensaje).';
      feedback.className   = 'contact__feedback error';
      feedback.setAttribute('aria-hidden', 'false');
      return;
    }

    const emailRe = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!emailRe.test(email)) {
      feedback.textContent = 'Por favor, introduce un email válido.';
      feedback.className   = 'contact__feedback error';
      feedback.setAttribute('aria-hidden', 'false');
      return;
    }

    // TODO: Replace with your real form endpoint (Formspree, Netlify Forms, etc.)
    // Simulated success for demo purposes
    feedback.textContent = '¡Mensaje enviado! Te responderemos en menos de 24 horas.';
    feedback.className   = 'contact__feedback success';
    feedback.setAttribute('aria-hidden', 'false');
    form.reset();
  });
</script>
