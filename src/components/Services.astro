---
import { services } from '@data/services';
import * as Lucide from '@lucide/astro';
---

<section
  id="services"
  class="services section-spacing"
  aria-labelledby="services-heading"
>
  <div class="container-gutter">
    <!-- Header -->
    <div class="services__header">
      <span class="services__label reveal-up">Nuestros servicios</span>
      <h2 id="services-heading" class="services__heading reveal-up">
        Todo lo que tu mascota<br/>
        <em>necesita</em>, en un solo lugar.
      </h2>
      <p class="services__sub reveal-up">
        Ofrecemos atención veterinaria integral con el equipamiento más avanzado
        y el equipo más dedicado.
      </p>
    </div>

    <!-- Grid -->
    <div class="services__grid" data-stagger-parent>
      {services.map((service) => (
        <article
          class="service-card"
          data-stagger-child
          data-accent={service.accent}
          style={`--service-accent: ${service.accent}`}
          aria-label={service.title}
        >
          <div class="service-card__glow" aria-hidden="true"></div>
          <div class="service-card__inner">
            <span class="service-card__emoji" aria-hidden="true">
              {(() => {
                const Icon = Lucide[service.emoji];
                return Icon ? <Icon stroke-width="2" class="w-10 h-10 inline-block align-middle" /> : null;
              })()}
            </span>
            <h3 class="service-card__title">{service.title}</h3>
            <p class="service-card__desc">{service.shortDesc}</p>
            <ul class="service-card__features" aria-label={`Características de ${service.title}`}>
              {service.features.slice(0, 3).map((f) => (
                <li class="service-card__feature">
                  <span class="service-card__dot" aria-hidden="true">·</span>
                  {f}
                </li>
              ))}
            </ul>
            <a
              href={`/servicios/${service.id}`}
              class="service-card__link"
              aria-label={`Ver más sobre ${service.title}`}
            >
              <span>Ver más</span>
              <svg class="service-card__arrow" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <path d="M4 10h12M12 6l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>

  <!-- Dot pattern bg -->
  <div class="services__dots" aria-hidden="true"></div>
</section>

<style>
  .services {
    background: var(--color-charcoal);
    position: relative;
    overflow: hidden;
  }

  /* Dot texture */
  .services__dots {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(255, 255, 255, 0.06) 1px, transparent 1px);
    background-size: 28px 28px;
    pointer-events: none;
    z-index: 0;
  }

  .container-gutter { position: relative; z-index: 1; }

  /* Header */
  .services__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1rem;
    margin-bottom: clamp(3rem, 5vw, 5rem);
  }

  .services__label {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #8CC63F;
  }

  .services__heading {
    font-family: "Cormorant Garamond", Georgia, serif;
    font-size: clamp(2rem, 4vw, 3.75rem);
    font-weight: 500;
    line-height: 1.15;
    color: #ffffff;
    letter-spacing: -0.02em;
  }

  .services__heading em { color: #8CC63F; }

  .services__sub {
    max-width: 500px;
    font-size: clamp(0.9375rem, 1.1vw, 1.0625rem);
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.6);
  }

  /* Grid */
  .services__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5px;
    border: 1.5px solid rgba(255, 255, 255, 0.08);
    border-radius: 1.25rem;
    overflow: hidden;
  }

  /* Card */
  .service-card {
    position: relative;
    background: rgba(30, 30, 30, 0.8);
    overflow: hidden;
    cursor: pointer;
    transition: background 0.4s ease;
  }

  .service-card:hover { background: rgba(38, 38, 38, 0.95); }

  /* Glow */
  .service-card__glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      circle at 50% 0%,
      var(--service-accent, #2BAABC) 0%,
      transparent 65%
    );
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  .service-card:hover .service-card__glow { opacity: 0.12; }

  /* Inner */
  .service-card__inner {
    position: relative;
    padding: clamp(1.75rem, 3vw, 2.5rem);
    display: flex;
    flex-direction: column;
    height: 100%;
    gap: 0;
  }

  /* Emoji */
  .service-card__emoji {
    display: inline-block;
    font-size: 2.25rem;
    margin-bottom: 1rem;
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .service-card:hover .service-card__emoji { transform: scale(1.15); }

  /* Title */
  .service-card__title {
    font-family: "Cormorant Garamond", Georgia, serif;
    font-size: clamp(1.25rem, 2vw, 1.625rem);
    font-weight: 500;
    color: #ffffff;
    line-height: 1.2;
    margin-bottom: 0.75rem;
    letter-spacing: -0.01em;
  }

  /* Desc */
  .service-card__desc {
    font-size: 0.875rem;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: 1.25rem;
  }

  /* Features */
  .service-card__features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    margin-bottom: 1.75rem;
    flex: 1;
  }

  .service-card__feature {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.5);
    line-height: 1.4;
  }

  .service-card__dot {
    color: var(--service-accent, #2BAABC);
    font-size: 1.25rem;
    line-height: 1;
    flex-shrink: 0;
  }

  /* Link */
  .service-card__link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--service-accent, #2BAABC);
    text-decoration: none;
    transition: gap 0.3s ease;
    margin-top: auto;
  }

  .service-card__arrow {
    transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .service-card__link:hover .service-card__arrow {
    transform: translate(4px, -4px);
  }

  @media (max-width: 900px) {
    .services__grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 560px) {
    .services__grid { grid-template-columns: 1fr; }
  }
</style>
