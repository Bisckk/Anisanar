---
import { services } from '@data/services';
import ServiceCarousel from '@components/react/ServiceCarousel';

// Serialize: pass only plain-object fields React needs
const carouselServices = services.map(({ id, title, shortDesc, features, accent, image, imageAlt }) => ({
  id, title, shortDesc, features, accent, image, imageAlt,
}));
---

<section
  id="services"
  class="services section-spacing"
  aria-labelledby="services-heading"
>
  <div class="container-gutter">
    <!-- Header -->
    <div class="services__header">
      <span class="services__label reveal-up">Nuestros servicios</span>
      <h2 id="services-heading" class="services__heading reveal-up">
        Todo lo que tu mascota<br/>
        <em>necesita</em>, en un solo lugar.
      </h2>
      <p class="services__sub reveal-up">
        Ofrecemos atención veterinaria integral con el equipamiento más avanzado
        y el equipo más dedicado.
      </p>
    </div>
  </div>

  <!-- Carousel (full-bleed within section) -->
  <ServiceCarousel client:visible services={carouselServices} />

  <!-- Dot pattern bg -->
  <div class="services__dots" aria-hidden="true"></div>
</section>

<style>
  .services {
    background: var(--color-charcoal);
    position: relative;
    overflow: hidden;
  }

  /* Dot texture */
  .services__dots {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(255, 255, 255, 0.04) 1px, transparent 1px);
    background-size: 28px 28px;
    pointer-events: none;
    z-index: 0;
  }

  .container-gutter { position: relative; z-index: 1; }

  /* Header */
  .services__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1rem;
    margin-bottom: clamp(2.5rem, 4vw, 4rem);
  }

  .services__label {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #8CC63F;
  }

  .services__heading {
    font-family: "Lexend", system-ui, sans-serif;
    font-size: clamp(2rem, 4vw, 3.75rem);
    font-weight: 500;
    line-height: 1.15;
    color: #ffffff;
    letter-spacing: -0.02em;
  }

  .services__heading em { color: #8CC63F; }

  .services__sub {
    max-width: 500px;
    font-size: clamp(0.9375rem, 1.1vw, 1.0625rem);
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.6);
  }
</style>
