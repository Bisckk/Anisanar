---
import MasonryGallery from './react/MasonryGallery.jsx';
---

<section
  id="gallery"
  class="gallery section-spacing"
  aria-labelledby="gallery-heading"
>
  <div class="container-gutter gallery__header">
    <span class="gallery__label reveal-up">Galería</span>
    <h2 id="gallery-heading" class="gallery__heading reveal-up">
      Un vistazo a nuestra<br/><em>clínica</em>.
    </h2>
  </div>

  <MasonryGallery client:visible />

  <!-- Ola de transición → Testimonials (claro) -->
  <div class="gallery__wave" aria-hidden="true">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 72" preserveAspectRatio="none">
      <path d="M0,36 C240,72 480,0 720,28 C960,56 1200,8 1440,36 L1440,72 L0,72 Z" fill="#f8fafc"/>
    </svg>
  </div>
</section>

<style>
  .gallery {
    background: var(--color-charcoal);
    padding-top: 0;
    position: relative;
    overflow: hidden;
  }

  /* Ola de transición */
  .gallery__wave {
    position: absolute;
    bottom: -1px;
    left: 0;
    right: 0;
    line-height: 0;
  }

  .gallery__wave svg {
    display: block;
    width: 100%;
    height: 72px;
  }

  .gallery__header {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 3rem;
  }

  .gallery__label {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #8CC63F;
  }

  .gallery__heading {
    font-family: "Lexend", system-ui, sans-serif;
    font-size: clamp(2rem, 4vw, 3.75rem);
    font-weight: 500;
    line-height: 1.1;
    color: #ffffff;
    letter-spacing: -0.02em;
  }

  .gallery__heading em { color: #8CC63F; font-style: normal; }
</style>
