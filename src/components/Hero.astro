---
import BlurText from '@components/react/BlurText';
---

<section
  id="hero"
  class="hero"
  aria-label="Bienvenida — Anisanar Veterinaria"
>
  <!-- Background image -->
  <div class="hero__bg-wrap" aria-hidden="true">
    <div
      class="hero__bg"
      style="background-image: url('https://images.unsplash.com/photo-1548199973-03cce0bbc87b?w=1800&q=85')"
    ></div>
    <div class="hero__overlay"></div>
  </div>

  <!-- Bottom-anchored content -->
  <div class="hero__bottom container-gutter">

    <!-- Tag -->
    <div id="hero-tag" class="hero__tag" role="text">
      Centro Veterinario &middot; Madrid &middot; Est. 2009
    </div>

    <!-- Huge title -->
    <h1 class="hero__title" aria-label="Anisanar">
      <BlurText 
        text="ANISANAR" 
        delay={80} 
        animateBy="letters" 
        direction="bottom"
        className="hero__title-text"
        client:load 
      />
    </h1>

    <!-- Bottom left: desc + CTA + stats -->
    <div class="hero__left">
      <p id="hero-sub" class="hero__desc">
        En Anisanar combinamos medicina veterinaria de vanguardia con un trato cercano y humano. Desde consultas de rutina hasta cirugía especializada y urgencias 24 h, nuestro equipo está comprometido con la salud, el bienestar y la calidad de vida de tu mascota.
      </p>
      <div id="hero-ctas" class="hero__ctas">
        <a href="#contact" class="hero__cta-btn">
          <span>Agendar cita</span>
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
      <div id="hero-stats" class="hero__stats">
        <div class="hero__stat">
          <span class="hero__stat-number">15+</span>
          <span class="hero__stat-label">Años</span>
        </div>
        <div class="hero__stat">
          <span class="hero__stat-number">8K+</span>
          <span class="hero__stat-label">Pacientes</span>
        </div>
        <div class="hero__stat">
          <span class="hero__stat-number">24h</span>
          <span class="hero__stat-label">Urgencias</span>
        </div>
        <div class="hero__stat">
          <span class="hero__stat-number">4.9★</span>
          <span class="hero__stat-label">Google</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div id="hero-scroll" class="hero__scroll" aria-hidden="true">
    <span class="hero__scroll-line"></span>
    <span class="hero__scroll-label">scroll</span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end; /* anchor content to bottom */
    overflow: hidden;
    background: #0a0a0a;
  }

  /* ── BG ─────────────────────────────────────────────────────────────────── */
  .hero__bg-wrap {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    animation: slowZoom 25s ease-out forwards;
  }

  @keyframes slowZoom {
    0% { transform: scale(1); }
    100% { transform: scale(1.15); }
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.92) 0%,
      rgba(0, 0, 0, 0.5) 40%,
      rgba(0, 0, 0, 0.2) 70%,
      rgba(0, 0, 0, 0.35) 100%
    );
  }

  /* ── Bottom content ────────────────────────────────────────────────────── */
  .hero__bottom {
    position: relative;
    z-index: 1;
    padding-bottom: clamp(2.5rem, 5vh, 4rem);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0;
    max-width: none; /* Let title stretch full width */
    width: 100%;
  }

  /* ── Tag ────────────────────────────────────────────────────────────────── */
  .hero__tag {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 0.75rem;
  }

  /* ── Title ──────────────────────────────────────────────────────────────── */
  .hero__title {
    margin: 0;
    margin-bottom: clamp(1.5rem, 3vh, 2.5rem);
    overflow: hidden;
    width: 100%;
    align-self: stretch;
    /* Visual styles aquí para que hereden al React child */
    font-family: "Lexend", system-ui, sans-serif;
    font-size: clamp(3.5rem, 11vw, 14rem);
    font-weight: 900;
    color: #ffffff;
    letter-spacing: -0.05em;
    line-height: 0.82;
  }

  /* :global porque BlurText renderiza el <p> desde React (no recibe el scoped hash) */
  :global(.hero__title-text) {
    font-family: "Lexend", system-ui, sans-serif;
    font-size: clamp(3.5rem, 11vw, 14rem);
    font-weight: 900;
    color: #ffffff !important;
    letter-spacing: -0.05em;
    line-height: 0.82;
    text-transform: uppercase;
    display: flex !important;
    flex-wrap: wrap;
    justify-content: flex-start;
    width: 100%;
    margin: 0;
  }

  /* ── Bottom left block ─────────────────────────────────────────────────── */
  .hero__left {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    max-width: 600px;
  }

  .hero__desc {
    font-size: clamp(0.875rem, 1.1vw, 1.0625rem);
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.6);
    letter-spacing: 0.01em;
  }

  /* ── CTA ────────────────────────────────────────────────────────────────── */
  .hero__ctas {
    display: flex;
    gap: 1rem;
  }

  .hero__cta-btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    padding: clamp(0.75rem, 1.2vw, 1rem) clamp(1.5rem, 2.5vw, 2.25rem);
    border: 1.5px solid rgba(255, 255, 255, 0.45);
    border-radius: 0;
    color: #ffffff;
    font-size: clamp(0.75rem, 0.85vw, 0.9375rem);
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    background: transparent;
    overflow: hidden;
    transition: color 0.45s ease, border-color 0.45s ease;
  }

  /* Ola líquida que sube */
  .hero__cta-btn::before {
    content: '';
    position: absolute;
    bottom: -4px;
    left: -10%;
    width: 120%;
    height: 180%;
    background: #ffffff;
    border-radius: 45% 45% 0 0;
    transform: translateY(102%);
    transition: transform 0.6s cubic-bezier(0.23, 1, 0.32, 1);
    z-index: 0;
  }

  .hero__cta-btn span,
  .hero__cta-btn svg {
    position: relative;
    z-index: 1;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .hero__cta-btn:hover {
    color: #0a0a0a;
    border-color: #ffffff;
  }

  .hero__cta-btn:hover::before {
    transform: translateY(0%);
  }

  .hero__cta-btn:hover svg {
    transform: translateX(5px);
  }

  /* ── Stats ──────────────────────────────────────────────────────────────── */
  .hero__stats {
    display: flex;
    gap: clamp(1.5rem, 3vw, 3rem);
    flex-wrap: nowrap;
  }

  .hero__stat {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .hero__stat-number {
    font-family: "Lexend", system-ui, sans-serif;
    font-size: clamp(2rem, 4vw, 4rem);
    font-weight: 700;
    color: #ffffff;
    line-height: 1;
    letter-spacing: -0.03em;
  }

  .hero__stat-label {
    font-size: clamp(0.6rem, 0.7vw, 0.75rem);
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.35);
  }

  /* ── Scroll indicator ──────────────────────────────────────────────────── */
  .hero__scroll {
    position: absolute;
    bottom: 2.5rem;
    right: var(--spacing-gutter);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    opacity: 0;
    z-index: 1;
  }

  .hero__scroll-line {
    width: 1px;
    height: 50px;
    background: linear-gradient(to bottom, rgba(255, 255, 255, 0.6), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }

  .hero__scroll-label {
    font-size: 0.625rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.3);
    writing-mode: vertical-rl;
    text-orientation: mixed;
    transform: rotate(180deg);
  }

  @keyframes scrollPulse {
    0%, 100% { transform: scaleY(1); opacity: 0.6; }
    50%       { transform: scaleY(0.5); opacity: 1; }
  }

  /* ── Mobile ────────────────────────────────────────────────────────────── */
  @media (max-width: 768px) {
    .hero__left {
      max-width: 100%;
    }

    .hero__stats {
      gap: 1.5rem;
    }

    .hero__scroll { display: none; }
  }
</style>

<script>
  import { gsap } from 'gsap';

  gsap.set('#hero-tag',    { opacity: 0, y: 12 });
  gsap.set('#hero-sub',    { opacity: 0, y: 16 });
  gsap.set('#hero-ctas',   { opacity: 0, y: 16 });
  gsap.set('#hero-stats',  { opacity: 0, y: 20 });
  gsap.set('#hero-scroll', { opacity: 0 });

  function runHeroTimeline() {
    const tl = gsap.timeline({ defaults: { ease: 'expo.out' } });
    tl
      .to('#hero-tag',    { opacity: 1, y: 0, duration: 0.8 })
      .to('#hero-sub',    { opacity: 1, y: 0, duration: 0.8 }, '-=0.5')
      .to('#hero-ctas',   { opacity: 1, y: 0, duration: 0.7 }, '-=0.5')
      .to('#hero-stats',  { opacity: 1, y: 0, duration: 0.7 }, '-=0.4')
      .to('#hero-scroll', { opacity: 1,       duration: 0.5 }, '-=0.2');
  }

  document.addEventListener('preloader:done', runHeroTimeline);

  // Fallback
  setTimeout(() => {
    const tag = document.getElementById('hero-tag');
    if (tag && getComputedStyle(tag).opacity === '0') runHeroTimeline();
  }, 3000);
</script>
