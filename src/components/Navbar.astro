---
import CardNav    from './react/CardNav.jsx';
import { getImage } from 'astro:assets';
import logoAsset  from '../assets/logo-anisanar.png';
const optimizedLogo = await getImage({ src: logoAsset, width: 64, height: 64, format: 'webp', quality: 90 });
---

<header id="navbar" class="navbar-wrapper" role="banner">
  <CardNav client:load logoSrc={optimizedLogo.src} />
</header>

<style>
  .navbar-wrapper {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    width: 100%;
    pointer-events: none; /* Let clicks pass through the wrapper itself */
  }

  /* Make sure the child container receives pointer events */
  .navbar-wrapper :global(.card-nav-container) {
    pointer-events: auto;
  }
</style>

