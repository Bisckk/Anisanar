---
const links = [
  { href: '#about',        label: 'Nosotros' },
  { href: '#services',     label: 'Servicios' },
  { href: '#team',         label: 'Equipo' },
  { href: '#testimonials', label: 'Reseñas' },
  { href: '#contact',      label: 'Contacto' },
];
---

<header id="navbar" class="navbar" role="banner">
  <div class="navbar__inner container-gutter">
    <!-- Logo -->
    <a href="/" class="navbar__logo" aria-label="Anisanar Veterinaria — Inicio">
      <img src="/logo-anisanar.png" alt="Anisanar" class="navbar__logo-img" />
      <span class="navbar__logo-text"><span class="logo-ani">ANI</span><span class="logo-sanar">SANAR</span></span>
    </a>

    <!-- Desktop nav -->
    <nav class="navbar__nav" aria-label="Navegación principal">
      {links.map(({ href, label }) => (
        <a href={href} class="navbar__link">{label}</a>
      ))}
    </nav>

    <!-- CTA -->
    <a href="#contact" class="btn-primary navbar__cta" aria-label="Agendar cita en Anisanar">
      Agendar cita
    </a>

    <!-- Mobile burger -->
    <button
      id="burger"
      class="navbar__burger"
      aria-label="Abrir menú de navegación"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="burger-bar bar-1"></span>
      <span class="burger-bar bar-2"></span>
      <span class="burger-bar bar-3"></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <nav
    id="mobile-menu"
    class="navbar__mobile"
    aria-label="Menú móvil"
    aria-hidden="true"
  >
    {links.map(({ href, label }) => (
      <a href={href} class="navbar__mobile-link">{label}</a>
    ))}
    <a href="#contact" class="btn-primary" style="align-self:flex-start;margin-top:1rem">
      Agendar cita
    </a>
  </nav>
</header>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    padding: 1.25rem 0;
    transition: background 0.4s ease, box-shadow 0.4s ease, padding 0.4s ease;
  }

  .navbar.scrolled {
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    box-shadow: 0 1px 0 rgba(30, 41, 59, 0.06), 0 4px 24px rgba(0, 0, 0, 0.06);
    padding: 0.75rem 0;
  }

  .navbar__inner {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  /* Logo */
  .navbar__logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    margin-right: auto;
  }

  .navbar__logo-img {
    height: 32px;
    width: auto;
    object-fit: contain;
    border-radius: 4px;
  }

  .navbar__logo-text {
    font-family: 'Montserrat', sans-serif;
    font-size: 1.5rem;
    font-weight: 800;
    letter-spacing: 1px;
    display: flex;
  }

  .logo-ani {
    color: #8CC63F;
  }

  .logo-sanar {
    color: #2BAABC;
    font-style: italic;
  }

  /* Desktop nav */
  .navbar__nav {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .navbar__link {
    position: relative;
    font-size: 0.875rem;
    font-weight: 400;
    letter-spacing: 0.04em;
    color: rgba(255, 255, 255, 0.85);
    text-decoration: none;
    padding: 0.4rem 0.75rem;
    transition: color 0.4s ease;
  }

  .navbar__link:hover { color: #ffffff; }

  /* When scrolled, links become dark */
  .navbar.scrolled .navbar__link { color: rgba(30, 41, 59, 0.75); }
  .navbar.scrolled .navbar__link:hover { color: var(--color-charcoal); }

  .navbar__link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0.75rem;
    right: 0.75rem;
    height: 1px;
    background: #8CC63F;
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .navbar__link:hover::after { transform: scaleX(1); transform-origin: left; }

  /* CTA */
  .navbar__cta { font-size: 0.8125rem; padding: 0.65rem 1.4rem; }

  /* Burger */
  .navbar__burger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    width: 36px;
    height: 36px;
    cursor: pointer;
    padding: 0;
  }

  .burger-bar {
    display: block;
    height: 1.5px;
    background: rgba(255, 255, 255, 0.9);
    border-radius: 2px;
    transform-origin: center;
    transition: background 0.4s ease;
  }

  .navbar.scrolled .burger-bar {
    background: rgba(30, 41, 59, 0.8);
  }

  /* Mobile menu */
  .navbar__mobile {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 1.5rem var(--spacing-gutter);
    background: rgba(255, 255, 255, 0.97);
    backdrop-filter: blur(20px);
    overflow: hidden;
    max-height: 0;
    transition: max-height 0.5s cubic-bezier(0.16, 1, 0.3, 1), padding 0.4s ease;
    padding-top: 0;
    padding-bottom: 0;
  }

  .navbar__mobile.open {
    max-height: 500px;
    padding-top: 1.5rem;
    padding-bottom: 2rem;
  }

  .navbar__mobile-link {
    font-size: 1.5rem;
    font-family: "Cormorant Garamond", Georgia, serif;
    font-style: italic;
    color: rgba(30, 41, 59, 0.8);
    text-decoration: none;
    padding: 0.5rem 0;
    border-bottom: 1px solid rgba(30, 41, 59, 0.08);
    transition: color 0.25s ease;
  }

  .navbar__mobile-link:hover { color: #8CC63F; }

  @media (max-width: 768px) {
    .navbar__nav, .navbar__cta { display: none; }
    .navbar__burger { display: flex; }
  }
</style>

<script>
  import { gsap } from 'gsap';

  // ─── Entry animation ────────────────────────────────────────────────────────
  gsap.fromTo('#navbar',
    { yPercent: -100, opacity: 0 },
    { yPercent: 0, opacity: 1, duration: 1, ease: 'expo.out', delay: 0.2 }
  );

  // ─── Hide/show on scroll ────────────────────────────────────────────────────
  const navbar = document.getElementById('navbar')!;
  let lastY = 0;
  let ticking = false;

  window.addEventListener('scroll', () => {
    if (!ticking) {
      requestAnimationFrame(() => {
        const currentY = window.scrollY;

        if (currentY > 60) {
          navbar.classList.add('scrolled');
        } else {
          navbar.classList.remove('scrolled');
        }

        // Umbral de tolerancia para no disparar animaciones por micro-movimientos de Lenis
        if (Math.abs(currentY - lastY) > 5) {
          if (currentY > lastY && currentY > 120) {
            gsap.to(navbar, { yPercent: -100, duration: 0.4, ease: 'power2.out', overwrite: 'auto' });
          } else {
            gsap.to(navbar, { yPercent: 0, duration: 0.5, ease: 'expo.out', overwrite: 'auto' });
          }
          lastY = currentY;
        }

        ticking = false;
      });
      ticking = true;
    }
  });

  // ─── Mobile burger ──────────────────────────────────────────────────────────
  const burger     = document.getElementById('burger')!;
  const mobileMenu = document.getElementById('mobile-menu')!;
  const bar1 = burger.querySelector('.bar-1') as HTMLElement;
  const bar2 = burger.querySelector('.bar-2') as HTMLElement;
  const bar3 = burger.querySelector('.bar-3') as HTMLElement;
  let menuOpen = false;

  burger.addEventListener('click', () => {
    menuOpen = !menuOpen;
    burger.setAttribute('aria-expanded', String(menuOpen));
    mobileMenu.setAttribute('aria-hidden', String(!menuOpen));
    mobileMenu.classList.toggle('open', menuOpen);

    if (menuOpen) {
      gsap.to(bar1, { rotate: 45,  y: 6.5,  duration: 0.35, ease: 'expo.out' });
      gsap.to(bar2, { opacity: 0,            duration: 0.2 });
      gsap.to(bar3, { rotate: -45, y: -6.5, duration: 0.35, ease: 'expo.out' });
    } else {
      gsap.to(bar1, { rotate: 0, y: 0, duration: 0.35, ease: 'expo.out' });
      gsap.to(bar2, { opacity: 1,           duration: 0.2 });
      gsap.to(bar3, { rotate: 0, y: 0, duration: 0.35, ease: 'expo.out' });
    }
  });

  // Close mobile menu on link click
  mobileMenu.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menuOpen = false;
      burger.setAttribute('aria-expanded', 'false');
      mobileMenu.setAttribute('aria-hidden', 'true');
      mobileMenu.classList.remove('open');
      gsap.to([bar1, bar3], { rotate: 0, y: 0, duration: 0.35, ease: 'expo.out' });
      gsap.to(bar2, { opacity: 1, duration: 0.2 });
    });
  });
</script>
